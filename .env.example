# Server Configuration
PORT=5000
MONGODB_URI=mongodb://localhost:27017/luxe-ecom
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# Frontend URL — used to build password reset links in emails
# Local dev:   http://localhost:5173
# Production:  https://your-frontend.onrender.com
FRONTEND_URL=http://localhost:5173

# ─── Gmail SMTP (password reset emails) ──────────────────────────────────────
#
# Uses your Gmail account to send transactional emails via Nodemailer.
# Requires a Gmail App Password (NOT your regular Gmail password).
#
# SETUP STEPS:
#   1. Enable 2-Step Verification on your Google Account
#      → https://myaccount.google.com/security
#   2. Go to: Google Account → Security → 2-Step Verification → App passwords
#   3. Create a new App Password (name it "THE ELEGANT" or anything)
#   4. Copy the 16-character password shown (spaces are ignored)
#   5. Paste it as SMTP_APP_PASSWORD below
#
# ▼ Fill these in ▼
SMTP_EMAIL=your-gmail@gmail.com
SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Razorpay Payment Gateway (Test Mode) ────────────────────────────────────
#
# SETUP STEPS:
#   1. Sign up / Log in at https://dashboard.razorpay.com
#   2. Make sure you are in TEST MODE (toggle top-left of dashboard)
#   3. Go to: Settings → API Keys → Generate Test Key
#   4. Copy the Key ID  (starts with rzp_test_)  → RAZORPAY_KEY_ID
#   5. Copy the Key Secret                        → RAZORPAY_KEY_SECRET
#      (Secret is shown only once — save it immediately)
#
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary Configuration (Optional - fallback to local storage if missing)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
